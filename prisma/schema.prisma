generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

enum UserRole {
  member
  artist
  admin
}

enum ArtistStatus {
  pending
  approved
  rejected
}

enum InventoryStatus {
  in_stock
  sold_out
  archived
}

enum CharityContentType {
  activity
  project
}

enum OrderStatus {
  pending_payment
  pending_shipment
  in_transit
  completed
  cancelled
}

enum TransactionType {
  order_payment
  manual_adjustment
  refund
}

model User {
  id                 String        @id @default(cuid())
  email              String        @unique
  passwordHash       String
  username           String?       @unique
  realName           String?
  avatarUrl          String?
  phone              String?
  role               UserRole      @default(member)
  artistStatus       ArtistStatus?
  bio                String?       @db.Text
  artistIntro        String?       @db.Text
  portfolioUrl       String?
  isActive           Boolean       @default(true)
  total_spent        Decimal       @default(0) @db.Decimal(12, 2)
  current_tier_level Int           @default(0)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  artworks           Artwork[]
  orders             Order[]
  transactions       Transaction[]

  @@index([role])
  @@index([artistStatus])
  @@index([current_tier_level])
}

model Artwork {
  id                 String          @id @default(cuid())
  artistId           String
  artist             User            @relation(fields: [artistId], references: [id], onDelete: Cascade)
  title              String
  slug               String          @unique
  imageUrl           String
  price              Decimal         @db.Decimal(10, 2)
  stock              Int             @default(1)
  inventoryStatus    InventoryStatus @default(in_stock)
  description        String?         @db.Text
  charitySupportNote String          @db.Text
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  @@index([artistId])
  @@index([inventoryStatus])
}

model CharityContent {
  id        String             @id @default(cuid())
  legacyId  Int?
  kind      CharityContentType
  slug      String             @unique
  title     String
  cover     String
  dateLabel String
  author    String
  location  String?
  tag       String?
  summary   String?            @db.Text
  sections  Json
  images    Json
  published Boolean            @default(true)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  @@unique([kind, legacyId])
  @@index([kind, published])
}

model Order {
  id               String      @id @default(cuid())
  orderNo          String      @unique
  userId           String?
  user             User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  buyerName        String
  buyerEmail       String
  buyerPhone       String?
  shippingAddress  String?
  status           OrderStatus @default(pending_shipment)
  totalAmount      Decimal     @db.Decimal(10, 2)
  items            Json
  logisticsCompany String?
  logisticsNumber  String?
  trackingNote     String?     @db.Text
  shippedAt        DateTime?
  deliveredAt      DateTime?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  transactions     Transaction[]

  @@index([userId, createdAt])
  @@index([status, createdAt])
}

model Transaction {
  id                  String          @id @default(cuid())
  userId              String
  user                User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  orderId             String?
  order               Order?          @relation(fields: [orderId], references: [id], onDelete: SetNull)
  type                TransactionType @default(order_payment)
  amount              Decimal         @db.Decimal(12, 2)
  total_spent_snapshot Decimal        @db.Decimal(12, 2)
  tier_level_snapshot Int
  perks               Json?
  note                String?         @db.Text
  createdAt           DateTime        @default(now())

  @@index([userId, createdAt])
  @@index([orderId])
  @@index([type, createdAt])
}
